MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/restaurant?retryWrites=true&w=majority
NEXTAUTH_SECRET=replace-with-a-long-random-secret
NEXTAUTH_URL=https://your-vercel-domain.vercel.app
NEXT_PUBLIC_SITE_URL=https://your-vercel-domain.vercel.app
PALMA_ADMIN_PASSWORD=replace-with-a-strong-admin-password
PALMA_ADMIN_SESSION_TOKEN=replace-with-a-long-random-token

# Optional: enables durable room image uploads on Vercel.
# Created automatically when you connect a Vercel Blob store to the project.
BLOB_READ_WRITE_TOKEN=

# Optional: enables reservation notification emails.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
RESERVATION_EMAIL_TO=
RESERVATION_EMAIL_FROM=
